# ──────────────────────────────────────────────
# Interxchange — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and adjust as needed.
# docker-compose reads these values automatically.

# ── PostgreSQL ─────────────────────────────────
POSTGRES_USER=interxchange
POSTGRES_PASSWORD=interxchange
POSTGRES_DB=interxchange
POSTGRES_HOST_PORT=5433

# ── Redis ─────────────────────────────────────
# 6380 avoids conflict if another Redis is on 6379
REDIS_HOST_PORT=6380

# ── Vault ─────────────────────────────────────
VAULT_HOST_PORT=8200
VAULT_TOKEN=dev_token

# ── Backend ───────────────────────────────────
BACKEND_HOST_PORT=8000
JWT_SECRET_KEY=dev_jwt_secret
JWT_REFRESH_SECRET_KEY=dev_refresh_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────
FRONTEND_HOST_PORT=5173
VITE_API_URL=http://localhost:8000/api/v1
