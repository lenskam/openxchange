# Backend environment variables (for manual / non-Docker runs).
# When using docker-compose, these are overridden by the root .env file.

DATABASE_URL=postgresql+asyncpg://interxchange:interxchange@localhost:5432/interxchange
REDIS_URL=redis://localhost:6380/0
JWT_SECRET_KEY=dev_jwt_secret
JWT_REFRESH_SECRET_KEY=dev_refresh_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev_token
ENVIRONMENT=development
LOG_LEVEL=INFO
